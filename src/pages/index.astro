---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>Dmitrii Naumenko</h1>
				<p class="tagline">Senior Software Engineer · Cloud Architect · Python Team Lead</p>
				<p class="bio">
					Hey 👋, I'm Dmitrii! I'm a Senior Software Engineer, Cloud Architect, and Python team lead
					focused on building reliable, high-performance backend systems. I love solving challenging
					engineering problems, designing scalable cloud architecture, and leading teams.
				</p>
			</section>

			<section class="recent">
				<h2>Recent posts</h2>
				<ul>
					{
						recentPosts.map((post) => (
							<li>
								<a class="post-link" href={`/blog/${post.id}/`}>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
									<span class="title">{post.data.title}</span>
								</a>
								<p class="desc">{post.data.description}</p>
							</li>
						))
					}
				</ul>
				<a class="all-posts" href="/blog/">View all posts →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		margin-bottom: 3rem;
	}
	.intro h1 {
		margin: 0 0 0.25rem 0;
	}
	.tagline {
		margin: 0 0 1.25rem 0;
		color: var(--accent);
		font-weight: 600;
	}
	.bio {
		margin: 0;
		color: rgb(var(--gray-dark));
	}
	.recent h2 {
		margin: 0 0 1.25rem 0;
	}
	.recent ul {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.recent li {
		padding: 1rem 0;
		border-top: 1px solid rgb(var(--gray-light));
	}
	.recent li:last-of-type {
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.post-link {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		text-decoration: none;
	}
	.post-link .date {
		flex: 0 0 auto;
		min-width: 8.5rem;
		color: rgb(var(--gray));
		font-size: 0.9rem;
	}
	.post-link .title {
		color: rgb(var(--black));
		font-weight: 600;
	}
	.post-link:hover .title {
		color: var(--accent);
	}
	.desc {
		margin: 0.35rem 0 0 9.5rem;
		color: rgb(var(--gray));
		font-size: 0.95rem;
	}
	.all-posts {
		display: inline-block;
		margin-top: 1.5rem;
		font-weight: 600;
	}
	@media (max-width: 720px) {
		.post-link {
			flex-direction: column;
			gap: 0.15rem;
		}
		.desc {
			margin-left: 0;
		}
	}
</style>
